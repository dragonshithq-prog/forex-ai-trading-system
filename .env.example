# =============================================================================
# Forex AI Trading Platform — Environment Configuration
# =============================================================================
# Instructions:
#   1. Copy this file to .env:  cp .env.example .env
#   2. Fill in all REQUIRED fields (marked with "REQUIRED")
#   3. Review OPTIONAL fields and adjust as needed
#   4. NEVER commit .env to version control
# =============================================================================

# ═════════════════════════════════════════════════════════════════════════════
# REQUIRED — Application Secrets
# ═════════════════════════════════════════════════════════════════════════════

# Application
# ----------------------------------------------------------------------------
APP_NAME="Forex AI Trading System"
ENVIRONMENT=development           # development | staging | production
SECRET_KEY=change-me-in-production  # Generate: openssl rand -hex 32
DEBUG=true                        # Set false in production

# PostgreSQL
# ----------------------------------------------------------------------------
POSTGRES_DB=forex_trading
POSTGRES_USER=forex
POSTGRES_PASSWORD=changeme_db_password  # REQUIRED — Generate: openssl rand -base64 24
DATABASE_URL=postgresql+asyncpg://forex:changeme_db_password@localhost:5432/forex_trading

# Redis
# ----------------------------------------------------------------------------
REDIS_PASSWORD=changeme_redis_password  # REQUIRED — Generate: openssl rand -base64 24
REDIS_URL=redis://:changeme_redis_password@localhost:6379/0

# JWT Authentication
# ----------------------------------------------------------------------------
JWT_SECRET_KEY=your-jwt-secret-change-in-production  # REQUIRED — Generate: openssl rand -hex 64
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Grafana (monitoring dashboard)
# ----------------------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme_grafana_password  # REQUIRED
GRAFANA_SECRET_KEY=changeme_grafana_secret         # REQUIRED — Generate: openssl rand -hex 32

# ═════════════════════════════════════════════════════════════════════════════
# OPTIONAL — Server & API
# ═════════════════════════════════════════════════════════════════════════════

HOST=0.0.0.0
PORT=8000
API_PREFIX=/api/v1
BACKEND_WORKERS=4                 # Number of gunicorn workers
CORS_ORIGINS=http://localhost:3000,http://localhost:80
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                   # json | plain

# ═════════════════════════════════════════════════════════════════════════════
# OPTIONAL — Database
# ═════════════════════════════════════════════════════════════════════════════

DATABASE_ECHO=false               # Log all SQL queries (dev only)
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_RECYCLE=1800        # Seconds

# ═════════════════════════════════════════════════════════════════════════════
# OPTIONAL — Kafka (Message Bus)
# ═════════════════════════════════════════════════════════════════════════════

KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk
KAFKA_NUM_PARTITIONS=6
KAFKA_REPLICATION_FACTOR=1

# ═════════════════════════════════════════════════════════════════════════════
# OPTIONAL — Risk Management
# ═════════════════════════════════════════════════════════════════════════════

MAX_POSITION_SIZE_PCT=2.0         # Max position size as % of account
MAX_TOTAL_EXPOSURE_PCT=20.0       # Max total exposure as % of account
MAX_DRAWDOWN_DAILY_PCT=3.0        # Max daily drawdown %
MAX_DRAWDOWN_TOTAL_PCT=15.0       # Max total drawdown %
MAX_POSITIONS=10                  # Max concurrent open positions
RISK_PER_TRADE_PCT=1.0            # Risk per trade as % of account

# ═════════════════════════════════════════════════════════════════════════════
# OPTIONAL — AI/ML Configuration
# ═════════════════════════════════════════════════════════════════════════════

AI_MIN_AGENTS=4                   # Minimum AI agents for consensus
AI_MIN_AGREEMENT_THRESHOLD=0.60   # Minimum consensus agreement (0.0-1.0)
AI_MAX_CONFLICT_THRESHOLD=0.30    # Maximum allowed conflict (0.0-1.0)
AI_ENSEMBLE_METHOD=weighted       # weighted | majority | unanimous

# ═════════════════════════════════════════════════════════════════════════════
# OPTIONAL — Broker Integration (fill in for live trading)
# ═════════════════════════════════════════════════════════════════════════════

OANDA_API_KEY=
OANDA_ACCOUNT_ID=
OANDA_ENVIRONMENT=practice         # practice | live

MT5_ACCOUNT_NUMBER=
MT5_PASSWORD=
MT5_SERVER=

# ═════════════════════════════════════════════════════════════════════════════
# OPTIONAL — Monitoring & Observability
# ═════════════════════════════════════════════════════════════════════════════

PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=8000
OTEL_SERVICE_NAME=forex-trading-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
JAEGER_ENDPOINT=http://localhost:14268/api/traces
SENTRY_DSN=                       # Sentry error tracking DSN

# ═════════════════════════════════════════════════════════════════════════════
# OPTIONAL — Docker & Deployment
# ═════════════════════════════════════════════════════════════════════════════

IMAGE_TAG=latest                  # Docker image tag
REGISTRY=ghcr.io                  # Container registry
REPO_NAME=org/forex-trading       # GitHub repository name
