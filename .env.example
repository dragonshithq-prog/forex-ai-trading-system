# Application
APP_NAME=Forex AI Trading System
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me-in-production
API_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql+asyncpg://forex:forex@localhost:5432/forex_trading
DATABASE_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# JWT
JWT_SECRET_KEY=your-jwt-secret-change-in-production
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Risk Management
MAX_POSITION_SIZE_PCT=2.0
MAX_TOTAL_EXPOSURE_PCT=20.0
MAX_DRAWDOWN_DAILY_PCT=3.0
MAX_DRAWDOWN_TOTAL_PCT=15.0
MAX_POSITIONS=10
RISK_PER_TRADE_PCT=1.0

# AI Configuration
AI_MIN_AGENTS=4
AI_MIN_AGREEMENT_THRESHOLD=0.60
AI_MAX_CONFLICT_THRESHOLD=0.30

# Broker (fill in your credentials)
OANDA_API_KEY=
OANDA_ACCOUNT_ID=
OANDA_ENVIRONMENT=practice

# Monitoring
PROMETHEUS_ENABLED=true
LOG_LEVEL=INFO
LOG_FORMAT=json
