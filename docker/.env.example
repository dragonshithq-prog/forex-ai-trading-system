# =============================================================================
# Forex AI Trading Platform — Docker Compose Environment
# =============================================================================
# This file documents all environment variables used by docker-compose.yml.
# Copy to .env in the docker/ directory or use the root .env file.
#
# Usage:
#   docker compose --env-file .env -f docker-compose.yml up -d
# =============================================================================

# ═════════════════════════════════════════════════════════════════════════════
# REQUIRED — Database & Cache
# ═════════════════════════════════════════════════════════════════════════════

# PostgreSQL
POSTGRES_DB=forex_trading
POSTGRES_USER=forex
POSTGRES_PASSWORD=changeme_db_password       # REQUIRED — Generate: openssl rand -base64 24

# Redis
REDIS_PASSWORD=changeme_redis_password       # REQUIRED — Generate: openssl rand -base64 24

# ═════════════════════════════════════════════════════════════════════════════
# REQUIRED — Monitoring
# ═════════════════════════════════════════════════════════════════════════════

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme_grafana_pass  # REQUIRED
GRAFANA_SECRET_KEY=changeme_grafana_secret    # REQUIRED

# ═════════════════════════════════════════════════════════════════════════════
# OPTIONAL — Application
# ═════════════════════════════════════════════════════════════════════════════

APP_NAME="Forex AI Trading System"
ENVIRONMENT=development
LOG_LEVEL=INFO
DEBUG=true
SECRET_KEY=change-me-in-production

# ═════════════════════════════════════════════════════════════════════════════
# OPTIONAL — Docker Registry
# ═════════════════════════════════════════════════════════════════════════════

IMAGE_TAG=latest
REGISTRY=ghcr.io
REPO_NAME=org/forex-trading

# ═════════════════════════════════════════════════════════════════════════════
# OPTIONAL — Domain Configuration
# ═════════════════════════════════════════════════════════════════════════════

NEXT_PUBLIC_API_URL=https://api.yourdomain.com
NEXT_PUBLIC_WS_URL=wss://api.yourdomain.com/ws
GRAFANA_ROOT_URL=https://monitoring.yourdomain.com
