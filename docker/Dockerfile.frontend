# =============================================================================
# Forex AI Trading Platform — Frontend Dockerfile (Production Multi-Stage)
# =============================================================================
# Stage 1 (deps)    : Install all npm dependencies (cached layer)
# Stage 2 (builder) : Build Next.js application with standalone output
# Stage 3 (runner)  : Minimal node:20-alpine image, non-root user
# =============================================================================

# ── Stage 1: Dependency Installation ─────────────────────────────────────────
FROM node:20-alpine AS deps

LABEL stage="deps"

# Install libc compatibility for native modules on Alpine
RUN apk add --no-cache libc6-compat

WORKDIR /app

# Copy package manifests first (layer-cache optimisation — invalidate only on lock change)
COPY frontend/package.json frontend/package-lock.json* ./

# Install exact production + dev dependencies (dev needed for build step)
RUN npm ci --frozen-lockfile

# ── Stage 2: Next.js Builder ──────────────────────────────────────────────────
FROM node:20-alpine AS builder

LABEL stage="builder"

RUN apk add --no-cache libc6-compat

WORKDIR /app

# Copy dependencies from deps stage
COPY --from=deps /app/node_modules ./node_modules

# Copy full frontend source
COPY frontend/ .

# Build arguments that become Next.js public env vars at build time
ARG NEXT_PUBLIC_API_URL=https://api.yourdomain.com
ARG NEXT_PUBLIC_WS_URL=wss://api.yourdomain.com/ws
ARG NEXT_PUBLIC_APP_VERSION=local

ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL} \
    NEXT_PUBLIC_WS_URL=${NEXT_PUBLIC_WS_URL} \
    NEXT_PUBLIC_APP_VERSION=${NEXT_PUBLIC_APP_VERSION} \
    NODE_ENV=production \
    # Disable Next.js telemetry in CI/builds
    NEXT_TELEMETRY_DISABLED=1

# Build the Next.js application
# Requires next.config.js to include: output: 'standalone'
RUN npm run build

# ── Stage 3: Production Runner ────────────────────────────────────────────────
FROM node:20-alpine AS runner

ARG BUILD_DATE
ARG GIT_SHA
LABEL org.opencontainers.image.created="${BUILD_DATE}" \
      org.opencontainers.image.revision="${GIT_SHA}" \
      org.opencontainers.image.title="forex-trading-frontend" \
      org.opencontainers.image.description="Forex AI Trading Platform — Frontend" \
      org.opencontainers.image.vendor="Forex Trading Platform"

RUN apk add --no-cache \
        libc6-compat \
        curl \
        ca-certificates \
    && apk upgrade --no-cache

ENV NODE_ENV=production \
    NEXT_TELEMETRY_DISABLED=1 \
    PORT=3000 \
    HOSTNAME=0.0.0.0

# Create non-root user before copying any files
RUN addgroup --system --gid 1001 nodejs && \
    adduser  --system --uid 1001 --ingroup nodejs nextjs

WORKDIR /app

# Copy only the standalone output from builder stage
# standalone/ contains: server.js + a self-contained node_modules snapshot
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/.next/static    ./.next/static
COPY --from=builder --chown=nextjs:nodejs /app/public          ./public

# Switch to non-root user
USER nextjs

EXPOSE 3000

# Health check
HEALTHCHECK --interval=15s --timeout=10s --start-period=30s --retries=3 \
    CMD curl -f http://localhost:3000 || exit 1

# Run the standalone Next.js server (generated by output: 'standalone')
CMD ["node", "server.js"]
